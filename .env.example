# =============================================================================
# ENVIRONMENT CONFIGURATION - KapanNikah Backend
# =============================================================================
# CARA PAKAI:
#   1. Copy file ini: cp .env.example .env
#   2. Ganti nilai di bawah sesuai data Anda
#   3. JANGAN pernah commit file .env ke Git!
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
# NODE_ENV: development | production | test
NODE_ENV=development
PORT=3000
# URL server ini sendiri (digunakan untuk generate link verifikasi email)
APP_URL=http://localhost:3000

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
#
# Cara dapatkan:
#   1. Buka https://cloud.mongodb.com
#   2. Klik cluster Anda -> Connect -> Drivers
#   3. Copy connection string, ganti <db_password> dengan password Anda
#   4. Tambahkan nama database sebelum tanda tanya (contoh: .../kapannikah?)
#
# Contoh (GANTI dengan data Anda):
MONGO_URI=mongodb+srv://kapannikah:RahasiaPassword123@version1.idl2ike.mongodb.net/kapannikah?retryWrites=true&w=majority&appName=Version1

# ── JWT (JSON Web Token) ──────────────────────────────────────────────────────
# SECRET harus panjang dan acak. Dua secret ini HARUS BERBEDA.
# Cara generate secret baru di terminal:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#
JWT_ACCESS_SECRET=a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4
JWT_REFRESH_SECRET=z9y8x7w6v5u4z9y8x7w6v5u4z9y8x7w6v5u4z9y8x7w6v5u4z9y8x7w6v5u4z9y8x7w6v5u4z9y8x7w6v5u4z9y8x7w6
# Durasi access token kadaluarsa (15m = 15 menit)
JWT_ACCESS_EXPIRES_IN=15m
# Durasi refresh token kadaluarsa (7d = 7 hari)
JWT_REFRESH_EXPIRES_IN=7d

# ── Keamanan ──────────────────────────────────────────────────────────────────
# Semakin tinggi BCRYPT_SALT_ROUNDS, semakin aman tapi semakin lambat. 12 sudah cukup.
BCRYPT_SALT_ROUNDS=12
# CORS: URL frontend yang diizinkan akses API (pisahkan dengan koma jika lebih dari satu)
CORS_ORIGIN=http://localhost:3000,http://localhost:4000

# ── OTP (One-Time Password) ───────────────────────────────────────────────────
# Berapa menit OTP berlaku sebelum kadaluarsa
OTP_EXPIRES_IN_MINUTES=5
# Maksimal berapa kali boleh salah memasukkan OTP sebelum diminta ulang
OTP_MAX_ATTEMPTS=3

# ── Email (untuk kirim OTP & reset password) ──────────────────────────────────
# Untuk testing gratis, gunakan Mailtrap: https://mailtrap.io
# Daftar -> Inbox -> SMTP Settings -> copy data di bawah
EMAIL_HOST=sandbox.smtp.mailtrap.io
EMAIL_PORT=587
EMAIL_USER=abc123def456dummy
EMAIL_PASS=xyz789dummy000pass
EMAIL_FROM="KapanNikah" <no-reply@manzastudio.id>

# ── Logging ───────────────────────────────────────────────────────────────────
# Level: error | warn | info | http | debug
LOG_LEVEL=info
