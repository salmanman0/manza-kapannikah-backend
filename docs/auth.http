# =============================================================================
# KapanNikah API — Authentication
# =============================================================================
# Base URL  : http://localhost:3000/api/v1
# Auth Type : Bearer Token (isi @token setelah login)
#
# Cara pakai di VS Code:
#   Install ekstensi "REST Client" (humao.rest-client)
#   Klik "Send Request" di atas setiap ### baris
#
# Related: docs/profile.http
# =============================================================================

@baseUrl = http://localhost:3000/api/v1
@ct      = application/json

# Isi setelah login berhasil:
@token   = PASTE_ACCESS_TOKEN_DI_SINI


###############################################################################
# 1. REGISTER
###############################################################################
# Mendaftarkan akun baru dengan email dan password.
# Setelah register: email verifikasi dikirim ke email yang didaftarkan.
# User BELUM bisa login sampai email diverifikasi.
# Response TIDAK mengandung token.
#
# Method  : POST
# URL     : /auth/register
# Auth    : Tidak diperlukan
# Rate    : Max 5 request per 15 menit per IP
# -----------------------------------------------------------------------------

### Register - Berhasil
POST {{baseUrl}}/auth/register
Content-Type: {{ct}}

{
  "name": "Budi Santoso",
  "email": "budi@example.com",
  "phone": "08123456789",
  "password": "Rahasia@123",
  "confirmPassword": "Rahasia@123",
  "kota": "Jakarta",
  "provinsi": "DKI Jakarta",
  "layanan": "pasangan"
}

# ✅ 201 Created
# {
#   "success": true,
#   "message": "Silahkan verifikasi email anda dengan meninjau email yang kami kirimkan"
# }
#
# ❌ 409 Conflict — email sudah terdaftar
# { "success": false, "message": "Email sudah terdaftar" }
#
# ❌ 422 Unprocessable — validasi gagal
# {
#   "success": false,
#   "message": "Validasi gagal",
#   "errors": [
#     { "field": "layanan", "message": "Layanan hanya boleh: pasangan, keluarga, atau tim" }
#   ]
# }
#
# Body Fields:
#   name            string  required  Min 2, max 100 karakter
#   email           string  required  Format email valid
#   phone           string  optional  Format Indonesia: 08xx / +628xx
#   password        string  required  Min 8 karakter, harus ada: A-Z, a-z, 0-9, simbol
#   confirmPassword string  required  Harus sama dengan password
#   kota            string  optional  Nama kota (maks 100 karakter)
#   provinsi        string  optional  Nama provinsi (maks 100 karakter)
#   layanan         string  optional  "pasangan" | "keluarga" | "tim"  (default: "pasangan")


###############################################################################
# 2. VERIFY EMAIL
###############################################################################
# Verifikasi email dari link yang dikirim ke email setelah register.
# Link berlaku 24 jam. Setelah berhasil, akun bisa digunakan untuk login.
#
# Method  : GET
# URL     : /auth/verify-email?token=<token>
# Auth    : Tidak diperlukan
# Trigger : User klik link dari email
# -----------------------------------------------------------------------------

### Verify Email - Berhasil
GET {{baseUrl}}/auth/verify-email?token=abcdef1234567890abcdef1234567890abcdef1234567890abcdef1234567890

# ✅ 200 OK
# { "success": true, "message": "Email berhasil diverifikasi. Silakan login." }
#
# ❌ 400 Bad Request — token tidak valid atau expired
# { "success": false, "message": "Link verifikasi tidak valid atau sudah kedaluwarsa. Silakan daftar ulang." }
#
# Query Params:
#   token  string  required  Token yang ada di link email (64 karakter hex)
#
# NOTE (development): Jika RESEND_API_KEY belum dikonfigurasi, link verifikasi
# akan muncul di terminal/log server. Copy dan akses URL tersebut di browser.


###############################################################################
# 3. LOGIN
###############################################################################
# Login dengan email dan password.
# Mengembalikan access token yang berlaku hingga logout.
# Gagal jika email belum diverifikasi.
#
# Method  : POST
# URL     : /auth/login
# Auth    : Tidak diperlukan
# Rate    : Max 5 request per 15 menit per IP
# -----------------------------------------------------------------------------

### Login - Berhasil
POST {{baseUrl}}/auth/login
Content-Type: {{ct}}

{
  "email": "budi@example.com",
  "password": "Rahasia@123"
}

# ✅ 200 OK
# {
#   "success": true,
#   "message": "Login berhasil",
#   "data": {
#     "user": {
#       "id": "6640a1b2c3d4e5f6a7b8c9d0",
#       "name": "Budi Santoso",
#       "email": "budi@example.com",
#       "phone": "08123456789",
#       "kota": "Jakarta",
#       "provinsi": "DKI Jakarta",
#       "layanan": "pasangan",
#       "initials": "BS",
#       "isEmailVerified": true,
#       "role": "user"
#     },
#     "accessToken": "a3f9b1c2d4e5f6..."   ← simpan ini ke @token di atas
#   }
# }
#
# ❌ 401 Unauthorized — email/password salah
# { "success": false, "message": "Email atau password salah" }
#
# ❌ 401 Unauthorized — email belum diverifikasi
# { "success": false, "message": "Akun Anda belum melakukan verified email. Silahkan cek email untuk melakukan verifikasi" }
#
# Body Fields:
#   email     string  required
#   password  string  required


###############################################################################
# 4. LOGIN DENGAN GOOGLE
###############################################################################
# Login atau register menggunakan akun Google.
# Mobile app mendapatkan idToken dari Google Sign-In SDK,
# lalu mengirimkannya ke endpoint ini.
#
# Flow:
#   1. Mobile → Google Sign-In SDK → dapat idToken
#   2. Mobile → POST /auth/google { idToken }
#   3. Backend verifikasi token ke Google
#   4. Jika email belum terdaftar → akun dibuat otomatis (email langsung terverifikasi)
#   5. Jika sudah terdaftar → login langsung
#
# Method  : POST
# URL     : /auth/google
# Auth    : Tidak diperlukan
# Rate    : Max 5 request per 15 menit per IP
# -----------------------------------------------------------------------------

### Login / Register dengan Google
POST {{baseUrl}}/auth/google
Content-Type: {{ct}}

{
  "idToken": "PASTE_GOOGLE_ID_TOKEN_DARI_SDK"
}

# ✅ 200 OK
# {
#   "success": true,
#   "message": "Login dengan Google berhasil",
#   "data": {
#     "user": {
#       "id": "6640a1b2c3d4e5f6a7b8c9d0",
#       "name": "Budi Santoso",
#       "email": "budi@gmail.com",
#       "phone": null,
#       "kota": null,
#       "provinsi": null,
#       "layanan": "pasangan",
#       "initials": "BS",
#       "isEmailVerified": true,
#       "role": "user"
#     },
#     "accessToken": "a3f9b1c2d4e5f6..."
#   }
# }
#
# ❌ 401 Unauthorized — token Google tidak valid
# { "success": false, "message": "Google token tidak valid" }
#
# ❌ 401 Unauthorized — akun Google belum verifikasi email
# { "success": false, "message": "Akun Google belum terverifikasi" }
#
# Body Fields:
#   idToken  string  required  ID token dari Google Sign-In SDK


###############################################################################
# 5. LOGOUT
###############################################################################
# Logout dari device saat ini.
# Access token yang digunakan langsung dihapus dari database.
#
# Method  : POST
# URL     : /auth/logout
# Auth    : Bearer Token (required)
# -----------------------------------------------------------------------------

### Logout
POST {{baseUrl}}/auth/logout
Authorization: Bearer {{token}}

# ✅ 200 OK
# { "success": true, "message": "Logout berhasil" }
#
# ❌ 401 Unauthorized — token tidak valid
# { "success": false, "message": "Token tidak valid atau sesi sudah berakhir. Silakan login kembali." }


###############################################################################
# 6. LOGOUT SEMUA PERANGKAT
###############################################################################
# Menghapus semua sesi aktif di semua perangkat.
# Berguna jika akun dicurigai dibobol atau setelah ganti password.
#
# Method  : POST
# URL     : /auth/logout-all
# Auth    : Bearer Token (required)
# -----------------------------------------------------------------------------

### Logout Semua Perangkat
POST {{baseUrl}}/auth/logout-all
Authorization: Bearer {{token}}

# ✅ 200 OK
# { "success": true, "message": "Logout dari semua perangkat berhasil" }
#
# ❌ 401 Unauthorized — tanpa token
# { "success": false, "message": "Autentikasi diperlukan" }


###############################################################################
# 7. LUPA PASSWORD
###############################################################################
# Flow:
#   1. User klik "Lupa Password" di aplikasi
#   2. User masukkan email → POST /auth/forgot-password
#   3. Email dikirim berisi link → https://manzastudio.id/reset-password?token=xxx
#   4. User klik link → dibuka di browser (halaman web ubah password)
#   5. User input password baru → POST /auth/reset-password
#   6. Password berhasil diubah, semua sesi dihapus
#
# Response selalu sama terlepas apakah email terdaftar atau tidak
# (mencegah user enumeration). Link berlaku 1 jam.
#
# Method  : POST
# URL     : /auth/forgot-password
# Auth    : Tidak diperlukan
# Rate    : Max 5 request per 15 menit per IP
# -----------------------------------------------------------------------------

### Lupa Password - Kirim Email
POST {{baseUrl}}/auth/forgot-password
Content-Type: {{ct}}

{
  "email": "budi@example.com"
}

# ✅ 200 OK (selalu sama meski email tidak terdaftar)
# { "success": true, "message": "Jika email terdaftar, instruksi reset password akan dikirim" }
#
# NOTE (development): Jika RESEND_API_KEY belum dikonfigurasi, link reset
# akan muncul di terminal/log server.
#
# Body Fields:
#   email  string  required


###############################################################################
# 8. RESET PASSWORD
###############################################################################
# Mengubah password menggunakan token dari email lupa password.
# Token didapat dari query string link di email: ?token=xxx
# Setelah berhasil, SEMUA sesi aktif dihapus — pengguna harus login ulang.
#
# Method  : POST
# URL     : /auth/reset-password
# Auth    : Tidak diperlukan
# -----------------------------------------------------------------------------

### Reset Password - Berhasil
POST {{baseUrl}}/auth/reset-password
Content-Type: {{ct}}

{
  "token": "PASTE_TOKEN_DARI_QUERY_STRING_LINK_EMAIL",
  "password": "PasswordBaru@456",
  "confirmPassword": "PasswordBaru@456"
}

# ✅ 200 OK
# { "success": true, "message": "Password berhasil direset. Silakan login kembali." }
#
# ❌ 400 Bad Request — token tidak valid atau sudah expired (> 1 jam)
# { "success": false, "message": "Token reset tidak valid atau sudah kedaluwarsa" }
#
# ❌ 422 Unprocessable — validasi gagal
# {
#   "success": false,
#   "message": "Validasi gagal",
#   "errors": [
#     { "field": "confirmPassword", "message": "Konfirmasi password tidak cocok" }
#   ]
# }
#
# Body Fields:
#   token            string  required  Token dari query string link email (64 karakter hex)
#   password         string  required  Password baru (min 8 karakter, ada A-Z, a-z, 0-9, simbol)
#   confirmPassword  string  required  Harus sama dengan password


###############################################################################
# HEALTH CHECK
###############################################################################

### Health Check
GET http://localhost:3000/api/health

# ✅ 200 OK
# {
#   "success": true,
#   "message": "Server is running",
#   "timestamp": "2026-04-20T07:22:56.000Z",
#   "version": "1.0.0"
# }
